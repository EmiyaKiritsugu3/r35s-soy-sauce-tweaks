	thermal-zones {
		phandle = <0xfc>;

		gpu-thermal {
			thermal-sensors = <0x84 0x01>;
			polling-delay-passive = <0x64>;
			phandle = <0x100>;
			polling-delay = <0x3e8>;
		};

		soc-thermal {
			sustainable-power = <0x2ee>;
			thermal-sensors = <0x84 0x00>;
			polling-delay-passive = <0x14>;
			phandle = <0xfd>;
			polling-delay = <0x3e8>;

			trips {

				trip-point-0 {
					type = "passive";
					hysteresis = <0x7d0>;
					temperature = <0x11170>;
					phandle = <0xfe>;
				};

				trip-point-1 {
					type = "passive";
					hysteresis = <0x7d0>;
					temperature = <0x14c08>;
					phandle = <0x85>;
				};

				soc-crit {
					type = "critical";
					hysteresis = <0x7d0>;
					temperature = <0x1c138>;
					phandle = <0xff>;
				};
			};

			cooling-maps {

				map0 {
					trip = <0x85>;
					cooling-device = <0x09 0xffffffff 0xffffffff>;
					contribution = <0x1000>;
				};

				map1 {
					trip = <0x85>;
					cooling-device = <0x86 0xffffffff 0xffffffff>;
					contribution = <0x1000>;
				};
			};
		};
	};

